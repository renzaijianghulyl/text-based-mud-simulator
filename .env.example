# LLM：阿里云 DashScope 兼容 OpenAI（通义千问 3.5 Plus）
LLM_API_KEY=your_api_key_here
# chat/completions 完整地址（北京区域默认如下；国际站见阿里云文档）
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# 兼容模式下的 model 名称（Qwen 3.5 Plus）
LLM_MODEL_PRIMARY=qwen3.5-plus
# 与 LLM_MODEL_PRIMARY 等价，二选一即可
# LLM_MODEL=qwen3.5-plus

# 可选：主模型失败时切换 DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_MODEL_FALLBACK=deepseek-chat

DB_CONNECTION_STRING=your_db_connection_string
WECHAT_APP_ID=your_app_id
