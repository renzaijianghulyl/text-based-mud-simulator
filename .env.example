# ======== 主路由 LLM（推荐：阿里云 DashScope 兼容 OpenAI）========
PRIMARY_LLM_API_KEY=your_api_key_here
PRIMARY_LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
PRIMARY_LLM_MODEL=qwen3.5-plus

# ======== 备路由 LLM（主模型失败时自动切换）========
FALLBACK_LLM_API_KEY=your_deepseek_api_key_here
FALLBACK_LLM_API_URL=https://api.deepseek.com/v1/chat/completions
FALLBACK_LLM_MODEL=deepseek-chat

# ======== 剧本与会话路径（CLI / 本地 HTTP）========
# 剧本包根目录；不设置则使用 <cwd>/scenarios
# SCENARIOS_ROOT=

# 本地会话 JSON 目录；不设置则使用 <cwd>/.sessions
# SESSIONS_DIR=

# ======== 本地 HTTP（npm run http:interact）========
# HTTP_INTERACT_HOST=127.0.0.1
# HTTP_INTERACT_PORT=8787

# ======== Prompt 档位 ========
# auto | fast | balanced | rich
PROMPT_PROFILE=auto

# ======== LLM 调参（可选，以下为默认值）========
# 单 provider 最大重试次数（云函数环境自动限制为 1）
# LLM_MAX_ATTEMPTS_PER_PROVIDER=1
# 采样温度 0~2，默认 0.7
# LLM_TEMPERATURE=0.7
# 单次补全最大 token
# LLM_MAX_OUTPUT_TOKENS=2048
# 单次请求超时（毫秒），云函数场景建议 120000
# LLM_REQUEST_TIMEOUT_MS=120000
